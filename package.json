{
  "name": "barberia-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd src/web/barberia-web && npm run dev",
    "build": "npm --prefix src/web/barberia-web install && npm --prefix src/web/barberia-web run build",
    "start": "npm --prefix src/web/barberia-web run start",
    "web:dev": "npm --prefix src/web/barberia-web run dev",
    "web:build": "npm --prefix src/web/barberia-web run build",
    "web:typecheck": "npm --prefix src/web/barberia-web run typecheck",
    "web:lint": "npm --prefix src/web/barberia-web run lint"
  }
}
