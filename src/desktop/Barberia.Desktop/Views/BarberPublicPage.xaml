<Page
    x:Class="Barberia.Desktop.Views.BarberPublicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Grid Background="#FFF9F9FC">
        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="White"
            BorderBrush="#FFE2E2E5"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="#FF1A1C1E"
                Glyph="&#xE700;" />
        </Button>

        <StackPanel
            Padding="48,96,48,48"
            MaxWidth="1400"
            HorizontalAlignment="Stretch"
            Spacing="24">
            <StackPanel Spacing="4">
                <TextBlock
                    FontFamily="Inter"
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="#FF1A1C1E"
                    Text="Barber Public" />
                <TextBlock
                    FontFamily="Inter"
                    FontSize="16"
                    Foreground="#FF444655"
                    Text="Manage barber availability status." />
                <TextBlock
                    x:Name="_messageText"
                    FontFamily="Inter"
                    FontSize="13"
                    Foreground="#FF444655" />
            </StackPanel>

            <Grid
                x:Name="_rosterGrid"
                RowSpacing="16"
                ColumnSpacing="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            </Grid>

            <Grid
                Padding="16"
                Background="#FFF9F9FC"
                BorderBrush="#FFE2E2E5"
                BorderThickness="0,1,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="_footerText"
                    VerticalAlignment="Center"
                    FontFamily="Inter"
                    FontSize="14"
                    Foreground="#FF444655" />
                <StackPanel
                    x:Name="_paginationPanel"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4">
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
