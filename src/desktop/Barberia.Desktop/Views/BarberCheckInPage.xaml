<Page
    x:Class="Barberia.Desktop.Views.BarberCheckInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Grid Background="{StaticResource SurfaceBrush}">
        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="{StaticResource TextPrimaryBrush}"
                Glyph="&#xE700;" />
        </Button>

        <ScrollViewer
            Padding="48,96,48,48"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="1160"
                HorizontalAlignment="Center"
                Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontFamily="Inter"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Barber Check-In" />
                        <TextBlock
                            FontFamily="Inter"
                            FontSize="16"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Register station arrivals to build today's turn rotation." />
                        <TextBlock
                            x:Name="_messageText"
                            FontFamily="Inter"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="18"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                FontFamily="Inter"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Station" />
                            <Grid>
                                <TextBox
                                    x:Name="_stationInput"
                                    MinHeight="52"
                                    Padding="14,10,48,10"
                                    CharacterCasing="Upper"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    HorizontalContentAlignment="Center"
                                    KeyDown="OnStationInputKeyDown"
                                    PlaceholderText="B-1"
                                    TextAlignment="Center" />
                                <FontIcon
                                    Margin="0,0,14,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Glyph="&#xE8FB;" />
                            </Grid>
                            <Button
                                MinHeight="48"
                                HorizontalAlignment="Stretch"
                                Background="#FF0020C2"
                                BorderBrush="#FF0020C2"
                                Click="OnCheckInClick"
                                Foreground="White"
                                ToolTipService.ToolTip="Check in station">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" />
                                    <TextBlock
                                        FontFamily="Inter"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="Check In" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <Grid
                            Padding="16"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                            <TextBlock
                                FontFamily="Inter"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Today's Rotation" />
                        </Grid>
                        <StackPanel
                            x:Name="_rotationPanel"
                            Spacing="0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>