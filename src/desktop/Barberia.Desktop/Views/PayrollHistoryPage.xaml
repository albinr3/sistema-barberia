<Page
    x:Class="Barberia.Desktop.Views.PayrollHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FFF9F9FC"
    Loaded="OnLoaded"
    SizeChanged="OnSizeChanged">

    <Page.Resources>
        <SolidColorBrush x:Key="PayrollSurfaceContainerBrush" Color="#FFEEEEF0" />
        <SolidColorBrush x:Key="PayrollSurfaceContainerLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="PayrollSurfaceContainerLowestBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="PayrollPrimaryBrush" Color="#FF001387" />
        <SolidColorBrush x:Key="PayrollPrimaryFixedBrush" Color="#FFDFE0FF" />
        <SolidColorBrush x:Key="PayrollOnPrimaryFixedVariantBrush" Color="#FF152DC9" />
        <SolidColorBrush x:Key="PayrollTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="PayrollMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="PayrollOutlineVariantBrush" Color="#FFC5C5D8" />
    </Page.Resources>

    <Grid>
        <ScrollViewer
            x:Name="_screenScrollViewer"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <Grid
                x:Name="_contentGrid"
                MaxWidth="1200"
                Padding="48,48,48,72"
                HorizontalAlignment="Center">
                <StackPanel Spacing="24">
                    <Grid
                        x:Name="_headerGrid"
                        ColumnSpacing="16"
                        RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="_headerTextColumn" Width="*" />
                            <ColumnDefinition x:Name="_headerActionsColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="_headerTextPanel">
                            <Button
                                x:Name="_btnBack"
                                Margin="0,0,0,16"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Click="OnBackClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{StaticResource PayrollPrimaryBrush}" />
                                    <TextBlock Text="Back to Payroll" Foreground="{StaticResource PayrollPrimaryBrush}" FontWeight="SemiBold" FontSize="14" />
                                </StackPanel>
                            </Button>
                            <TextBlock
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="{StaticResource PayrollTextBrush}"
                                Text="Payroll History" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="16"
                                Foreground="{StaticResource PayrollMutedTextBrush}"
                                Text="Review and manage past payroll periods."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Button
                            x:Name="_exportButton"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Padding="16,8"
                            Background="{StaticResource PayrollSurfaceContainerLowestBrush}"
                            BorderBrush="{StaticResource PayrollOutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Foreground="{StaticResource PayrollPrimaryBrush}"
                                    Glyph="&#xE896;" />
                                <TextBlock
                                    FontWeight="Medium"
                                    Foreground="{StaticResource PayrollPrimaryBrush}"
                                    Text="Export CSV" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        Padding="16"
                        Background="{StaticResource PayrollSurfaceContainerLowestBrush}"
                        BorderBrush="{StaticResource PayrollOutlineVariantBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid
                            x:Name="_filtersGrid"
                            ColumnSpacing="16"
                            RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="_filterSearchColumn" Width="*" />
                                <ColumnDefinition x:Name="_filterStatusColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="_searchBox"
                                Padding="12,8"
                                PlaceholderText="Search periods..."
                                VerticalAlignment="Center" />

                            <ComboBox
                                x:Name="_statusComboBox"
                                Grid.Column="1"
                                Width="150"
                                PlaceholderText="Status: All"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer
                        x:Name="_tableScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                        <Border
                            x:Name="_tableBorder"
                            MinWidth="860"
                            Background="{StaticResource PayrollSurfaceContainerLowestBrush}"
                            BorderBrush="{StaticResource PayrollOutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel>
                                <Grid
                                    Padding="24,16"
                                    Background="{StaticResource PayrollSurfaceContainerLowBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Reference #"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Period Date"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Processed Date"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="3"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Total Staff"
                                        TextAlignment="Right"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="4"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Total Payout"
                                        TextAlignment="Right"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="5"
                                        Margin="16,0,0,0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Status"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PayrollMutedTextBrush}"
                                        Text="Action"
                                        TextAlignment="Right"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <StackPanel x:Name="_historyLinesPanel" />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
