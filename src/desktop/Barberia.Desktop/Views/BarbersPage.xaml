<Page
    x:Class="Barberia.Desktop.Views.BarbersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE716;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="5">
                        <TextBlock
                            Style="{StaticResource HeroTitleTextStyle}"
                            Text="Barbers" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Manage team members, stations, and availability" />
                        <TextBlock
                            x:Name="_messageText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Spacing="10">
                        <Border
                            x:Name="_statusBadge"
                            Style="{StaticResource StatusBadgeStyle}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="7">
                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Fill="{StaticResource AccentGreenBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="_statusBadgeText"
                                    Style="{StaticResource StatusBadgeTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Button
                            MinHeight="42"
                            Click="OnRefreshClick"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Glyph="&#xE72C;" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Refresh" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid
                ColumnSpacing="14"
                RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.85*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Barber Editor" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Create barbers, assign fixed stations, edit their display order and choose an optional profile image." />
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Barber Name" />
                                <TextBox
                                    x:Name="_barberNameInput"
                                    MinHeight="46"
                                    PlaceholderText="e.g., Marcus"
                                    TextWrapping="NoWrap" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Station Code" />
                                <TextBox
                                    x:Name="_stationCodeInput"
                                    MinHeight="46"
                                    MaxLength="8"
                                    PlaceholderText="B-1"
                                    TextWrapping="NoWrap" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Rotation Order" />
                                <TextBox
                                    x:Name="_rotationOrderInput"
                                    MinHeight="46"
                                    MaxLength="4"
                                    PlaceholderText="0"
                                    TextWrapping="NoWrap" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Profile Image" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        x:Name="_profileImageSelector"
                                        MinHeight="46"
                                        HorizontalAlignment="Stretch"
                                        DisplayMemberPath="DisplayName"
                                        PlaceholderText="Use initials placeholder" />
                                    <Button
                                        Grid.Column="1"
                                        MinHeight="46"
                                        MinWidth="104"
                                        Click="OnBrowseProfileImageClick"
                                        Content="Browse" />
                                </Grid>
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Choose an image from Windows Explorer. Leave empty to use initials." />
                            </StackPanel>

                            <CheckBox
                                x:Name="_showInKioskCheckBox"
                                MinHeight="42"
                                Content="Show in kiosk and local operations"
                                IsChecked="True" />

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <Button
                                    MinHeight="44"
                                    Click="OnNewBarberClick"
                                    Content="New"
                                    HorizontalAlignment="Stretch" />
                                <Button
                                    Grid.Column="1"
                                    MinHeight="44"
                                    Click="OnSaveBarberClick"
                                    Content="Save"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource PrimaryActionButtonStyle}" />
                                <Button
                                    x:Name="_deleteBarberButton"
                                    Grid.Column="2"
                                    MinHeight="44"
                                    Click="OnDeleteBarberClick"
                                    Content="Delete"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Barber Directory" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Edit barbers or change availability when they are not called or in service." />
                        </StackPanel>
                        <StackPanel
                            x:Name="_barberRows"
                            Spacing="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
