<Page
    x:Class="Barberia.Desktop.Views.KioskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    SizeChanged="OnKioskSizeChanged"
    VerticalAlignment="Stretch">

    <Page.Resources>
        <SolidColorBrush x:Key="KioskBackgroundBrush" Color="#FFF9F9FC" />
        <SolidColorBrush x:Key="KioskSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="KioskSurfaceLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="KioskInputBrush" Color="#FFF1F3F5" />
        <SolidColorBrush x:Key="KioskOutlineBrush" Color="#FFC5C5D8" />
        <SolidColorBrush x:Key="KioskTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="KioskMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="KioskPrimaryBrush" Color="#FF001387" />
        <SolidColorBrush x:Key="KioskPrimaryContainerBrush" Color="#FF0020C2" />
        <SolidColorBrush x:Key="KioskAvailableBackgroundBrush" Color="#FFE6F4EA" />
        <SolidColorBrush x:Key="KioskAvailableTextBrush" Color="#FF137333" />
        <SolidColorBrush x:Key="KioskWaitBackgroundBrush" Color="#FFFEF7E0" />
        <SolidColorBrush x:Key="KioskWaitTextBrush" Color="#FFB06000" />
        <SolidColorBrush x:Key="KioskBusyBackgroundBrush" Color="#FFFFDAD6" />
        <SolidColorBrush x:Key="KioskBusyTextBrush" Color="#FF93000A" />
    </Page.Resources>

    <Grid
        x:Name="_pageRoot"
        Background="{StaticResource KioskBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Background="{StaticResource KioskSurfaceBrush}"
            BorderBrush="{StaticResource KioskOutlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                x:Name="_topBar"
                MinHeight="64"
                Padding="48,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid VerticalAlignment="Center">
                    <Image
                        x:Name="_brandLogo"
                        MaxWidth="230"
                        Height="42"
                        HorizontalAlignment="Left"
                        Stretch="Uniform" />
                    <TextBlock
                        x:Name="_brandFallbackText"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{StaticResource KioskPrimaryBrush}"
                        Text="Master Clips"
                        Visibility="Collapsed" />
                </Grid>

                <Button
                    Grid.Column="1"
                    Width="44"
                    Height="44"
                    Click="OnHelpButtonClick"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTipService.ToolTip="Show menu"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="22"
                        Foreground="{StaticResource KioskMutedTextBrush}"
                        Glyph="&#xE897;" />
                </Button>
            </Grid>
        </Border>

        <ScrollViewer
            x:Name="_screenScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            ZoomMode="Disabled">
            <Grid
                x:Name="_contentCanvas"
                MinHeight="1"
                Padding="48,42"
                HorizontalAlignment="Stretch">
                <Border
                    x:Name="_checkInPanel"
                    HorizontalAlignment="Stretch"
                    Padding="48"
                    Background="{StaticResource KioskSurfaceBrush}"
                    BorderBrush="{StaticResource KioskOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <StackPanel
                            Margin="0,0,0,40"
                            HorizontalAlignment="Center"
                            Spacing="8">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="48"
                                FontWeight="Bold"
                                Foreground="{StaticResource KioskPrimaryBrush}"
                                Text="Welcome, please check in"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="18"
                                Foreground="{StaticResource KioskMutedTextBrush}"
                                Text="Enter an optional name and select your preferred barber to join the queue."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel
                            x:Name="_nameInputSection"
                            MaxWidth="800"
                            Margin="0,0,0,40"
                            HorizontalAlignment="Stretch"
                            Spacing="8">
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource KioskTextBrush}"
                                Text="Your Name (optional)" />
                            <TextBox
                                x:Name="_customerNameInput"
                                MinHeight="56"
                                Padding="16,10"
                                Background="{StaticResource KioskInputBrush}"
                                BorderBrush="{StaticResource KioskOutlineBrush}"
                                BorderThickness="0,0,0,2"
                                CornerRadius="4,4,0,0"
                                FontSize="18"
                                GotFocus="OnCustomerNameFocus"
                                HorizontalAlignment="Stretch"
                                KeyDown="OnCustomerNameKeyDown"
                                PlaceholderText="e.g., John Doe"
                                TextChanged="OnCustomerNameChanged"
                                Tapped="OnCustomerNameTapped">
                                <TextBox.InputScope>
                                    <InputScope>
                                        <InputScope.Names>
                                            <InputScopeName NameValue="PersonalFullName" />
                                        </InputScope.Names>
                                    </InputScope>
                                </TextBox.InputScope>
                            </TextBox>
                            <TextBlock
                                x:Name="_nameErrorText"
                                Foreground="{StaticResource ErrorTextBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <Border
                            Height="1"
                            Margin="0,0,0,40"
                            Background="{StaticResource KioskOutlineBrush}" />

                        <StackPanel Margin="0,0,0,40">
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource KioskTextBrush}"
                                        Text="Select Barber" />
                                    <TextBlock
                                        MaxWidth="560"
                                        FontSize="15"
                                        Foreground="{StaticResource KioskMutedTextBrush}"
                                        Text="You can select one or multiple preferred barbers before printing your ticket."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="_selectionSummaryText"
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    FontSize="14"
                                    Foreground="{StaticResource KioskMutedTextBrush}" />
                            </Grid>

                            <Button
                                x:Name="_anyBarberButton"
                                MinHeight="64"
                                Margin="0,0,0,24"
                                HorizontalAlignment="Stretch"
                                Click="OnAnyBarberButtonClick"
                                IsEnabled="False"
                                Padding="18,12"
                                Background="{StaticResource KioskSurfaceBrush}"
                                BorderBrush="{StaticResource KioskPrimaryContainerBrush}"
                                BorderThickness="1.5"
                                CornerRadius="8">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <FontIcon
                                        FontSize="24"
                                        Foreground="{StaticResource KioskPrimaryContainerBrush}"
                                        Glyph="&#xE716;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource KioskPrimaryContainerBrush}"
                                        Text="ANY BARBER" />
                                </StackPanel>
                            </Button>

                            <Grid
                                x:Name="_barberGrid"
                                ColumnSpacing="16"
                                RowSpacing="16" />

                            <TextBlock
                                x:Name="_barberErrorText"
                                Margin="0,14,0,0"
                                Foreground="{StaticResource ErrorTextBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <Border
                            BorderBrush="{StaticResource KioskOutlineBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,24,0,0">
                            <Button
                                x:Name="_printTicketButton"
                                MinHeight="64"
                                HorizontalAlignment="Right"
                                Click="OnPrintTicketButtonClick"
                                IsEnabled="False"
                                Padding="32,14"
                                Background="{StaticResource KioskPrimaryContainerBrush}"
                                BorderBrush="{StaticResource KioskPrimaryContainerBrush}"
                                CornerRadius="8"
                                Foreground="White">
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="PRINT TICKET" />
                                    <FontIcon
                                        FontSize="22"
                                        Glyph="&#xE8A5;" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="_ticketPanel"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="40"
                    Background="{StaticResource KioskSurfaceBrush}"
                    BorderBrush="{StaticResource KioskOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                    <StackPanel Spacing="20">
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource KioskPrimaryContainerBrush}"
                            Text="Ticket Printed"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketNumberText"
                            FontSize="44"
                            FontWeight="Bold"
                            Foreground="{StaticResource KioskTextBrush}"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketCustomerText"
                            FontSize="20"
                            Foreground="{StaticResource KioskTextBrush}"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketBarberText"
                            FontSize="18"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_ticketMessageText"
                            FontSize="16"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_ticketTimeText"
                            FontSize="14"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center" />
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="OnStartNewButtonClick"
                            Content="New Check-in"
                            MinHeight="56" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
