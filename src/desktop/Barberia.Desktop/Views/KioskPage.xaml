<Page
    x:Class="Barberia.Desktop.Views.KioskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    SizeChanged="OnKioskSizeChanged"
    VerticalAlignment="Stretch">

    <Page.Resources>
        <SolidColorBrush x:Key="KioskBackgroundBrush" Color="#FFF9F9FC" />
        <SolidColorBrush x:Key="KioskSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="KioskSurfaceLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="KioskInputBrush" Color="#FFF1F3F5" />
        <SolidColorBrush x:Key="KioskOutlineBrush" Color="#FFC5C5D8" />
        <SolidColorBrush x:Key="KioskTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="KioskMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="KioskPrimaryBrush" Color="#FF001387" />
        <SolidColorBrush x:Key="KioskPrimaryContainerBrush" Color="#FF0020C2" />
        <SolidColorBrush x:Key="KioskAvailableBackgroundBrush" Color="#FFE6F4EA" />
        <SolidColorBrush x:Key="KioskAvailableTextBrush" Color="#FF137333" />
        <SolidColorBrush x:Key="KioskWaitBackgroundBrush" Color="#FFFEF7E0" />
        <SolidColorBrush x:Key="KioskWaitTextBrush" Color="#FFB06000" />
        <SolidColorBrush x:Key="KioskBusyBackgroundBrush" Color="#FFFFDAD6" />
        <SolidColorBrush x:Key="KioskBusyTextBrush" Color="#FF93000A" />
    </Page.Resources>

    <Grid
        x:Name="_pageRoot"
        Background="{StaticResource KioskBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Background="{StaticResource KioskSurfaceBrush}"
            BorderBrush="{StaticResource KioskOutlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                x:Name="_topBar"
                MinHeight="54"
                Padding="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    Width="44"
                    Height="44"
                    Click="OnHelpButtonClick"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTipService.ToolTip="Show menu"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="22"
                        Foreground="{StaticResource KioskMutedTextBrush}"
                        Glyph="&#xE700;" />
                </Button>

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Image
                        x:Name="_brandLogo"
                        MaxWidth="230"
                        Height="34"
                        HorizontalAlignment="Center"
                        Stretch="Uniform" />
                    <TextBlock
                        x:Name="_brandFallbackText"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{StaticResource KioskPrimaryBrush}"
                        Text="Master Clips"
                        TextAlignment="Center"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer
            x:Name="_screenScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            ZoomMode="Disabled">
            <Grid
                x:Name="_contentCanvas"
                MinHeight="1"
                Padding="28,10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <Border
                    x:Name="_checkInPanel"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Padding="20"
                    Background="{StaticResource KioskSurfaceBrush}"
                    BorderBrush="{StaticResource KioskOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid
                        x:Name="_checkInLayout"
                        RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel
                            x:Name="_introSection"
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            Spacing="4">
                            <TextBlock
                                x:Name="_titleText"
                                HorizontalAlignment="Center"
                                FontSize="34"
                                FontWeight="Bold"
                                Foreground="{StaticResource KioskPrimaryBrush}"
                                Text="Welcome, please check in"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="_subtitleText"
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{StaticResource KioskMutedTextBrush}"
                                Text="Enter an optional name and select your preferred barber to join the queue."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid
                            x:Name="_quickControlsGrid"
                            Grid.Row="1"
                            ColumnSpacing="18"
                            RowSpacing="8">
                            <StackPanel
                                x:Name="_nameInputSection"
                                MaxWidth="900"
                                HorizontalAlignment="Stretch"
                                Spacing="6">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource KioskTextBrush}"
                                    Text="Your Name (optional)"
                                    TextAlignment="Center" />
                                <TextBox
                                    x:Name="_customerNameInput"
                                    MinHeight="46"
                                    Padding="14,8"
                                    Background="{StaticResource KioskInputBrush}"
                                    BorderBrush="{StaticResource KioskOutlineBrush}"
                                    BorderThickness="0,0,0,2"
                                    CornerRadius="4,4,0,0"
                                    FontSize="16"
                                    GotFocus="OnCustomerNameFocus"
                                    HorizontalAlignment="Stretch"
                                    KeyDown="OnCustomerNameKeyDown"
                                    PlaceholderText="e.g., John Doe"
                                    TextAlignment="Center"
                                    TextChanged="OnCustomerNameChanged"
                                    Tapped="OnCustomerNameTapped">
                                    <TextBox.InputScope>
                                        <InputScope>
                                            <InputScope.Names>
                                                <InputScopeName NameValue="PersonalFullName" />
                                            </InputScope.Names>
                                        </InputScope>
                                    </TextBox.InputScope>
                                </TextBox>
                                <TextBlock
                                    x:Name="_nameErrorText"
                                    HorizontalAlignment="Stretch"
                                    Foreground="{StaticResource ErrorTextBrush}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>

                        <Grid
                            x:Name="_barberSectionGrid"
                            Grid.Row="2"
                            RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid
                                x:Name="_barberHeaderGrid"
                                Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource KioskTextBrush}"
                                        Text="Select Barber"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        MaxWidth="560"
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        Foreground="{StaticResource KioskMutedTextBrush}"
                                        Text="You can select one or multiple preferred barbers before printing your ticket."
                                        TextAlignment="Center"
                                        TextWrapping="WrapWholeWords" />
                                    <Button
                                        x:Name="_anyBarberButton"
                                        Margin="0,16,0,8"
                                        MinHeight="54"
                                        MinWidth="320"
                                        HorizontalAlignment="Center"
                                        Click="OnAnyBarberButtonClick"
                                        IsEnabled="False"
                                        Padding="32,10"
                                        Background="{StaticResource KioskSurfaceBrush}"
                                        BorderBrush="{StaticResource KioskPrimaryContainerBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="8">
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                            <FontIcon
                                                FontSize="22"
                                                Foreground="{StaticResource KioskPrimaryContainerBrush}"
                                                Glyph="&#xE716;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource KioskPrimaryContainerBrush}"
                                                Text="ANY BARBER"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Grid
                                x:Name="_barberGrid"
                                Grid.Row="1"
                                ColumnSpacing="10"
                                RowSpacing="10"
                                VerticalAlignment="Stretch" />

                            <TextBlock
                                x:Name="_barberErrorText"
                                Grid.Row="2"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                Foreground="{StaticResource ErrorTextBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />
                        </Grid>

                        <Border
                            x:Name="_printFooter"
                            Grid.Row="3"
                            BorderBrush="{StaticResource KioskOutlineBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0">
                            <Button
                                x:Name="_printTicketButton"
                                MinHeight="52"
                                HorizontalAlignment="Center"
                                Click="OnPrintTicketButtonClick"
                                IsEnabled="False"
                                Padding="28,12"
                                Background="{StaticResource KioskPrimaryContainerBrush}"
                                BorderBrush="{StaticResource KioskPrimaryContainerBrush}"
                                CornerRadius="8"
                                Foreground="White">
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Text="PRINT TICKET"
                                        TextAlignment="Center" />
                                    <FontIcon
                                        FontSize="20"
                                        Glyph="&#xE8A5;" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <Border
                    x:Name="_ticketPanel"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="40"
                    Background="{StaticResource KioskSurfaceBrush}"
                    BorderBrush="{StaticResource KioskOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                    <StackPanel Spacing="20">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource KioskPrimaryContainerBrush}"
                            Text="Ticket Printed"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketNumberText"
                            HorizontalAlignment="Center"
                            FontSize="44"
                            FontWeight="Bold"
                            Foreground="{StaticResource KioskTextBrush}"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketCustomerText"
                            HorizontalAlignment="Center"
                            FontSize="20"
                            Foreground="{StaticResource KioskTextBrush}"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="_ticketBarberText"
                            HorizontalAlignment="Stretch"
                            FontSize="18"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_ticketMessageText"
                            HorizontalAlignment="Stretch"
                            FontSize="16"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_ticketTimeText"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{StaticResource KioskMutedTextBrush}"
                            TextAlignment="Center" />
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="OnStartNewButtonClick"
                            Content="New Check-in"
                            MinHeight="56" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
