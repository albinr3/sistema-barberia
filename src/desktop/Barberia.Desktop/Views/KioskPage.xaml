<Page
    x:Class="Barberia.Desktop.Views.KioskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE8FA;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="18,2,0,0"
                        Spacing="5">
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Check-in de walk-ins" />
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Registro local para entrar a la cola de atencion" />
                    </StackPanel>

                    <Border
                        x:Name="_statusBadge"
                        Grid.Column="2"
                        Style="{StaticResource StatusBadgeStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="7">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource AccentGreenBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="_statusBadgeText"
                                Style="{StaticResource StatusBadgeTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.08*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource HeroCardBorderStyle}">
                    <StackPanel Spacing="18">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Entrada" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Toca el boton para registrar tu llegada. El sistema asigna el turno usando la cola local."
                            TextWrapping="Wrap" />
                        <Button
                            x:Name="_checkInButton"
                            MinHeight="112"
                            Padding="22"
                            Click="OnCheckInButtonClick"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            ToolTipService.ToolTip="Registrar walk-in local">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="14">
                                <FontIcon
                                    FontSize="28"
                                    Glyph="&#xE8FB;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Text="Registrar llegada" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource HeroCardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Ticket" />
                        <TextBlock
                            x:Name="_ticketNumber"
                            FontSize="34"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock
                            x:Name="_assignmentText"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentGreenBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_messageText"
                            Style="{StaticResource BodyTextStyle}" />
                        <TextBlock
                            x:Name="_timeText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8A5;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Sin servicio" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="El kiosco no pide seleccionar servicio ni precio." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE753;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Offline" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="El registro se guarda primero en SQLite local." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8EF;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Asignacion" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="La decision se delega al motor de turnos de Core." />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
