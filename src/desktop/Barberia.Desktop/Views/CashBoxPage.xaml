<Page
    x:Class="Barberia.Desktop.Views.CashBoxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    SizeChanged="OnSizeChanged">

    <Grid Background="#FFF9F9FC">
        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="{StaticResource TextPrimaryBrush}"
                Glyph="&#xE700;" />
        </Button>

        <ScrollViewer
            x:Name="_screenScrollViewer"
            Padding="48,96,48,32">
            <StackPanel
                MaxWidth="1200"
                HorizontalAlignment="Center"
                Spacing="24">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="#FF1A1C1E"
                        Text="Cash Box" />
                    <TextBlock
                        FontSize="16"
                        Foreground="#FF444655"
                        Text="Process transactions and close active tickets." />
                    <TextBlock
                        x:Name="_lastRefreshText"
                        FontSize="13"
                        Foreground="#FF757687" />
                </StackPanel>

                <Grid
                    x:Name="_cashBoxContentGrid"
                    ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="_activeTicketColumn" Width="7*" />
                        <ColumnDefinition x:Name="_paymentSummaryColumn" Width="3*" MinWidth="320" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Background="White"
                        BorderBrush="#FFE2E2E5"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <Border
                                Height="4"
                                VerticalAlignment="Top"
                                Background="#FF0020C2"
                                CornerRadius="12,12,0,0" />

                            <StackPanel
                                Padding="22"
                                Spacing="18">
                                <StackPanel
                                    Margin="0,8,0,0"
                                    Spacing="14">
                                    <Border
                                        Padding="0,0,0,16"
                                        BorderBrush="#FFE2E2E5"
                                        BorderThickness="0,0,0,1">
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <FontIcon
                                                FontSize="24"
                                                Foreground="#FF0020C2"
                                                Glyph="&#xE8A5;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="#FF1A1C1E"
                                                Text="Active Ticket" />
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="8">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="#FF444655"
                                                Text="Ticket Number" />
                                            <Grid>
                                                <TextBox
                                                    x:Name="_ticketInput"
                                                    Padding="42,12,14,12"
                                                    Background="#FFF3F3F6"
                                                    BorderBrush="#FFE2E2E5"
                                                    BorderThickness="0,0,0,2"
                                                    CornerRadius="6,6,0,0"
                                                    FontSize="16"
                                                    Foreground="#FF1A1C1E"
                                                    KeyDown="OnInputKeyDown"
                                                    LostFocus="OnTicketInputLostFocus"
                                                    TextChanged="OnTicketInputTextChanged"
                                                    PlaceholderText="e.g. 1042" />
                                                <FontIcon
                                                    Margin="14,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    FontSize="18"
                                                    Foreground="#FF757687"
                                                    Glyph="&#xE721;" />
                                            </Grid>
                                        </StackPanel>

                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Padding="16"
                                            Background="#FFF3F3F6"
                                            BorderBrush="#FFE2E2E5"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF444655"
                                                    Text="Customer" />
                                                <TextBlock
                                                    x:Name="_ticketCustomerText"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF1A1C1E"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Grid.Column="1"
                                            Padding="16"
                                            Background="#FFF3F3F6"
                                            BorderBrush="#FFE2E2E5"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF444655"
                                                    Text="Barber" />
                                                <TextBlock
                                                    x:Name="_ticketBarberText"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Foreground="#FF1A1C1E"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="18">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="8">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="#FF444655"
                                                Text="Select Service" />
                                            <Grid
                                                x:Name="_serviceOptionsGrid"
                                                ColumnSpacing="10"
                                                RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="12">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#FF444655"
                                            Text="Payment Method" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="_paymentMethodComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnPaymentMethodSelectionChanged">
                                                <ComboBoxItem Content="Cash" Tag="0" IsSelected="True" />
                                                <ComboBoxItem Content="Zelle" Tag="1" />
                                            </ComboBox>
                                            <TextBox x:Name="_paymentReferenceInput" Grid.Column="1" PlaceholderText="Zelle Reference (Optional)" Visibility="Collapsed" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="12">
                                        <Grid>
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="#FF444655"
                                                Text="Quick Additions" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="12"
                                                Foreground="#FF757687"
                                                Text="Common extra charges" />
                                        </Grid>

                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>

                                            <ToggleButton
                                                x:Name="_additional2Button"
                                                MinHeight="52"
                                                HorizontalAlignment="Stretch"
                                                Background="#FFF9F9FC"
                                                BorderBrush="#FFE2E2E5"
                                                BorderThickness="1"
                                                Click="OnAdditionalClick"
                                                Content="+ $2"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="#FF001387"
                                                Tag="2" />
                                            <ToggleButton
                                                x:Name="_additional3Button"
                                                Grid.Column="1"
                                                MinHeight="52"
                                                HorizontalAlignment="Stretch"
                                                Background="#FFF9F9FC"
                                                BorderBrush="#FFE2E2E5"
                                                BorderThickness="1"
                                                Click="OnAdditionalClick"
                                                Content="+ $3"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="#FF001387"
                                                Tag="3" />
                                            <ToggleButton
                                                x:Name="_additional5Button"
                                                Grid.Column="2"
                                                MinHeight="52"
                                                HorizontalAlignment="Stretch"
                                                Background="#FFF9F9FC"
                                                BorderBrush="#FFE2E2E5"
                                                BorderThickness="1"
                                                Click="OnAdditionalClick"
                                                Content="+ $5"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="#FF001387"
                                                Tag="5" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel
                        x:Name="_summaryPanel"
                        Grid.Column="1"
                        Spacing="24">
                        <Border
                            Padding="24"
                            Background="White"
                            BorderBrush="#FFE2E2E5"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel Spacing="24">
                                <Border
                                    Padding="0,0,0,16"
                                    BorderBrush="#FFE2E2E5"
                                    BorderThickness="0,0,0,1">
                                    <TextBlock
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Foreground="#FF1A1C1E"
                                        Text="Payment Summary" />
                                </Border>

                                <StackPanel Spacing="14">
                                    <Grid>
                                        <TextBlock
                                            FontSize="16"
                                            Foreground="#FF444655"
                                            Text="Subtotal" />
                                        <TextBlock
                                            x:Name="_amountText"
                                            HorizontalAlignment="Right"
                                            FontSize="16"
                                            Foreground="#FF444655" />
                                    </Grid>
                                    <Grid>
                                        <TextBlock
                                            FontSize="16"
                                            Foreground="#FF444655"
                                            Text="Additions" />
                                        <TextBlock
                                            x:Name="_commissionText"
                                            HorizontalAlignment="Right"
                                            FontSize="16"
                                            Foreground="#FF444655" />
                                    </Grid>

                                </StackPanel>

                                <Border
                                    Padding="0,24,0,0"
                                    BorderBrush="#FFE2E2E5"
                                    BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="#FF1A1C1E"
                                            Text="Total Amount" />
                                        <TextBlock
                                            x:Name="_cashTotalText"
                                            HorizontalAlignment="Right"
                                            FontSize="42"
                                            FontWeight="Bold"
                                            Foreground="#FF0020C2" />
                                    </Grid>
                                </Border>

                                <Button
                                    MinHeight="58"
                                    HorizontalAlignment="Stretch"
                                    Background="#FF0020C2"
                                    BorderBrush="#FF0020C2"
                                    Click="OnCloseClick"
                                    Foreground="White"
                                    ToolTipService.ToolTip="Complete cash transaction">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <FontIcon
                                            FontSize="20"
                                            Glyph="&#xE8C7;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Text="Complete Transaction" />
                                        </StackPanel>
                                </Button>

                                <TextBlock
                                    x:Name="_messageText"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="#FF1A1C1E"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="24"
                            Background="#FFF3F3F6"
                            BorderBrush="#FFE2E2E5"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <FontIcon
                                    Margin="0,2,0,0"
                                    FontSize="22"
                                    Foreground="#FF757687"
                                    Glyph="&#xE946;" />
                                <TextBlock
                                    x:Name="_serviceReceiptText"
                                    Grid.Column="1"
                                    FontSize="14"
                                    Foreground="#FF444655"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Button
                            MinHeight="48"
                            HorizontalAlignment="Stretch"
                            Background="#FFF3F3F6"
                            BorderBrush="#FFE2E2E5"
                            BorderThickness="1"
                            Click="OnPrintDayClick"
                            Foreground="#FF444655">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon FontSize="18" Glyph="&#xE749;" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Print Day Report" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
