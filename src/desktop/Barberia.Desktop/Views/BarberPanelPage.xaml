<Page
    x:Class="Barberia.Desktop.Views.BarberPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE77B;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="5">
                        <TextBlock
                            Style="{StaticResource HeroTitleTextStyle}"
                            Text="Panel de barbero" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Disponibilidad local, tickets asignados e inicio de atencion" />
                        <TextBlock
                            x:Name="_lastRefreshText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border
                        x:Name="_statusBadge"
                        Grid.Column="2"
                        Style="{StaticResource StatusBadgeStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="7">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource AccentGreenBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="_statusBadgeText"
                                Style="{StaticResource StatusBadgeTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource FormPanelBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Estado operativo" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Seleccion local del barbero" />
                        </StackPanel>

                        <StackPanel Spacing="14">
                            <ComboBox
                                x:Name="_barberSelector"
                                DisplayMemberPath="DisplayName"
                                PlaceholderText="Seleccionar barbero"
                                SelectionChanged="OnBarberSelectionChanged"
                                Style="{StaticResource OperationalComboBoxStyle}" />

                            <Border Style="{StaticResource InsetPanelBorderStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        x:Name="_barberStateText"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="_clientsTodayText"
                                        Style="{StaticResource SmallMutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <Button
                                    MinHeight="54"
                                    Padding="16,10,16,10"
                                    Background="{StaticResource AccentGreenBrush}"
                                    BorderBrush="{StaticResource AccentGreenBrush}"
                                    Click="OnAvailableClick"
                                    Foreground="{StaticResource SidebarBrush}"
                                    HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="Disponible">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <FontIcon
                                            FontSize="18"
                                            Glyph="&#xE8FB;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="Disponible" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Grid.Column="1"
                                    MinHeight="54"
                                    Padding="16,10,16,10"
                                    Background="{StaticResource AccentBlueTextBrush}"
                                    BorderBrush="{StaticResource AccentBlueTextBrush}"
                                    Click="OnOfflineClick"
                                    Foreground="{StaticResource SidebarBrush}"
                                    HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="Fuera de linea">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <FontIcon
                                            FontSize="18"
                                            Glyph="&#xE711;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="Fuera de linea" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource FormPanelBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Escaneo de ticket" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Inicia atencion solo con ticket asignado" />
                        </StackPanel>

                        <StackPanel Spacing="14">
                            <TextBox
                                x:Name="_ticketInput"
                                Header="Ticket"
                                KeyDown="OnTicketInputKeyDown"
                                PlaceholderText="Escanear o escribir numero de ticket"
                                Style="{StaticResource OperationalTextBoxStyle}" />
                            <Button
                                Click="OnStartServiceClick"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTipService.ToolTip="Iniciar atencion">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <FontIcon
                                        FontSize="18"
                                        Glyph="&#xE768;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="Iniciar atencion" />
                                </StackPanel>
                            </Button>
                            <TextBlock
                                x:Name="_messageText"
                                Style="{StaticResource BodyTextStyle}" />

                            <StackPanel Spacing="10">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Tickets asignados" />
                                <StackPanel
                                    x:Name="_assignedTurns"
                                    Spacing="10" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE73E;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Local" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="El panel lee y escribe en SQLite sin depender de internet." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8A5;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Sin cierre" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="No hay boton de terminar servicio en este panel." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8EF;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Autocaja" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="El pago y cierre operativo ocurren en autocaja." />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
