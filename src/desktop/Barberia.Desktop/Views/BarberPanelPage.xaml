<Page
    x:Class="Barberia.Desktop.Views.BarberPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Grid Background="{StaticResource SurfaceBrush}">
        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="{StaticResource TextPrimaryBrush}"
                Glyph="&#xE700;" />
        </Button>

        <Grid Padding="24">
            <Border
                MaxWidth="480"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="26">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Spacing="14">
                        <Border
                            Width="64"
                            Height="64"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="32">
                            <FontIcon
                                FontSize="30"
                                Foreground="{StaticResource AccentBlueTextBrush}"
                                Glyph="&#xE8B6;" />
                        </Border>

                        <StackPanel Spacing="6">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Start Service" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Scan the barber station first, then the customer ticket code."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Barber Station" />
                            <Grid>
                                <TextBox
                                    x:Name="_stationInput"
                                    Padding="14,12,48,12"
                                    CharacterCasing="Upper"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    HorizontalContentAlignment="Center"
                                    KeyDown="OnStationInputKeyDown"
                                    PlaceholderText="e.g. B-1"
                                    TextAlignment="Center" />
                                <FontIcon
                                    Margin="0,0,14,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Glyph="&#xE713;" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Ticket Code" />
                            <Grid>
                                <TextBox
                                    x:Name="_ticketInput"
                                    Padding="14,12,48,12"
                                    CharacterCasing="Upper"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    HorizontalContentAlignment="Center"
                                    KeyDown="OnTicketInputKeyDown"
                                    PlaceholderText="e.g. 24"
                                    TextAlignment="Center" />
                                <FontIcon
                                    Margin="0,0,14,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Glyph="&#xE8B6;" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Assigned Barber" />
                            <Border
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Glyph="&#xE77B;" />
                                    <TextBlock
                                        x:Name="_assignedBarberText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Waiting for scan..."
                                        TextTrimming="CharacterEllipsis" />
                                    <FontIcon
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Glyph="&#xE72E;" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Button
                            Click="OnStartServiceClick"
                            HorizontalAlignment="Stretch"
                            MinHeight="58"
                            Background="#FF0020C2"
                            BorderBrush="#FF0020C2"
                            Foreground="{StaticResource SurfaceBrush}"
                            ToolTipService.ToolTip="Start service">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="10">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Start Service" />
                                <FontIcon
                                    FontSize="18"
                                    Glyph="&#xE72A;" />
                            </StackPanel>
                        </Button>

                        <TextBlock
                            x:Name="_messageText"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
