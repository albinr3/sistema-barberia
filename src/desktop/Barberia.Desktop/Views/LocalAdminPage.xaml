<Page
    x:Class="Barberia.Desktop.Views.LocalAdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="56"
                        Height="56"
                        Background="{StaticResource AccentGreenBrush}"
                        CornerRadius="8">
                        <FontIcon
                            FontSize="26"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE713;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="18,2,0,0"
                        Spacing="5">
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Administracion local" />
                        <TextBlock
                            FontSize="14"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Base operativa" />
                    </StackPanel>

                    <Border
                        Grid.Column="2"
                        Background="{StaticResource AccentGoldMutedBrush}"
                        BorderBrush="{StaticResource AccentGoldBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8,12,8">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="7">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource AccentGoldBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource AccentGoldTextBrush}"
                                Text="Shell" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid
                ColumnSpacing="12"
                RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE787;" />
                        </Border>
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Dia" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Operacion local" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE716;" />
                        </Border>
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Equipo" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Barberos y estaciones" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE9D9;" />
                        </Border>
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Auditoria" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Eventos locales" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
