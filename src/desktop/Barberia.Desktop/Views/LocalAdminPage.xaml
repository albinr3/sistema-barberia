<Page
    x:Class="Barberia.Desktop.Views.LocalAdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE713;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="5">
                        <TextBlock
                            Style="{StaticResource HeroTitleTextStyle}"
                            Text="Local Admin" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Live operations, local database and team controls" />
                        <TextBlock
                            x:Name="_lastRefreshText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Spacing="10">
                        <Border
                            x:Name="_statusBadge"
                            Style="{StaticResource StatusBadgeStyle}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="7">
                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Fill="{StaticResource AccentGreenBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="_statusBadgeText"
                                    Style="{StaticResource StatusBadgeTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Button
                            MinHeight="42"
                            Click="OnRefreshClick"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Glyph="&#xE72C;" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Refresh" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Active turns" />
                            <TextBlock
                                x:Name="_activeTurnsText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGreenMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGreenTextBrush}"
                                Glyph="&#xE8A5;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Check-ins today" />
                            <TextBlock
                                x:Name="_checkInsText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentBlueMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentBlueTextBrush}"
                                Glyph="&#xE787;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Available barbers" />
                            <TextBlock
                                x:Name="_availableBarbersText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGoldMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGoldTextBrush}"
                                Glyph="&#xE716;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="3"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Cash today" />
                            <TextBlock
                                x:Name="_cashText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Glyph="&#xE8C7;" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Alerts / Problemas del momento" />
                        <TextBlock Style="{StaticResource SmallMutedTextStyle}" Text="Operational issues requiring attention." />
                    </StackPanel>
                    <StackPanel x:Name="_alertRows" Spacing="10" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Reassign Ticket" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Move a waiting or called ticket to an active barber." />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Ticket" />
                            <ComboBox
                                x:Name="_reassignTicketComboBox"
                                DisplayMemberPath="DisplayText"
                                HorizontalAlignment="Stretch"
                                MinHeight="42"
                                PlaceholderText="Select ticket"
                                SelectionChanged="OnReassignmentSelectionChanged" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Spacing="6">
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Target barber" />
                            <ComboBox
                                x:Name="_reassignBarberComboBox"
                                DisplayMemberPath="DisplayText"
                                HorizontalAlignment="Stretch"
                                MinHeight="42"
                                PlaceholderText="Select barber"
                                SelectionChanged="OnReassignmentSelectionChanged" />
                        </StackPanel>

                        <Button
                            x:Name="_reassignButton"
                            Grid.Column="2"
                            MinHeight="42"
                            MinWidth="120"
                            VerticalAlignment="Bottom"
                            Click="OnReassignTicketClick"
                            Content="Reassign" />
                    </Grid>
                </StackPanel>
            </Border>



            <Grid
                ColumnSpacing="14"
                RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Active Queue" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Waiting, called and in-service turns." />
                        </StackPanel>
                        <StackPanel
                            x:Name="_turnRows"
                            Spacing="10" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Audit Trail" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Most recent local events." />
                        </StackPanel>
                        <StackPanel
                            x:Name="_auditRows"
                            Spacing="10" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Ticket History Today" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Recently completed, cancelled or no-show tickets." />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Click="OnViewFullHistoryClick"
                            Content="View full history" />
                    </Grid>
                    <StackPanel
                        x:Name="_historyRows"
                        Spacing="10" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Local Database" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Current offline-first storage." />
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Database size" />
                            <TextBlock
                                x:Name="_databaseSizeText"
                                Grid.Column="1"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </Grid>
                        <TextBlock
                            x:Name="_databasePathText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="_messageText"
                            Style="{StaticResource SmallMutedTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
