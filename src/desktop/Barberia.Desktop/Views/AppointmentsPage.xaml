<Page
    x:Class="Barberia.Desktop.Views.AppointmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <Page.Resources>
        <SolidColorBrush x:Key="AdminBackgroundBrush" Color="#FFF9F9FC" />
        <SolidColorBrush x:Key="AdminSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AdminSurfaceLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="AdminSurfaceContainerBrush" Color="#FFEEEEF0" />
        <SolidColorBrush x:Key="AdminTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="AdminMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="AdminOutlineBrush" Color="#FF757687" />
        
        <Style x:Key="AdminCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AdminSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AdminSurfaceContainerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="AdminTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AdminTextBrush}" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource AdminBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <Grid MaxWidth="1200" Padding="48,96,48,72" HorizontalAlignment="Center">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource AdminTitleStyle}" Text="Today's Appointments" />
                        <TextBlock FontSize="16" Foreground="{StaticResource AdminMutedTextBrush}" Text="View the scheduled appointments for the current business day." />
                    </StackPanel>

                    <Border Style="{StaticResource AdminCardStyle}">
                        <StackPanel>
                            <Grid Padding="20,12,20,12" Background="{StaticResource AdminSurfaceLowBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Time" />
                                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Client" />
                                <TextBlock Grid.Column="2" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Barber" />
                                <TextBlock Grid.Column="3" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Service" />
                                <TextBlock Grid.Column="4" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Code" />
                                <TextBlock Grid.Column="5" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AdminMutedTextBrush}" Text="Status" />
                            </Grid>
                            
                            <StackPanel x:Name="_appointmentsRows" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AdminSurfaceBrush}"
            BorderBrush="{StaticResource AdminSurfaceContainerBrush}"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="{StaticResource AdminTextBrush}"
                Glyph="&#xE700;" />
        </Button>
    </Grid>
</Page>
