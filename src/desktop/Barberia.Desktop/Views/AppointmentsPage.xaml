<Page
    x:Class="Barberia.Desktop.Views.AppointmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Page.Resources>
        <SolidColorBrush x:Key="AdminBackgroundBrush" Color="#FFF9F9FC" />
        <SolidColorBrush x:Key="AdminSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AdminSurfaceLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="AdminSurfaceContainerBrush" Color="#FFEEEEF0" />
        <SolidColorBrush x:Key="AdminTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="AdminMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="AdminOutlineBrush" Color="#FF757687" />
        
        <Style x:Key="AdminCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AdminSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AdminSurfaceContainerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="_pageRoot"
        Background="{StaticResource AdminBackgroundBrush}"
        Tapped="OnPageRootTapped">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <Grid HorizontalAlignment="Stretch" Padding="48,110,48,72">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,32"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="42"
                        Foreground="{StaticResource AdminTextBrush}"
                        Glyph="&#xE783;" />
                    <TextBlock
                        FontSize="42"
                        FontWeight="Bold"
                        Foreground="{StaticResource AdminTextBrush}"
                        Text="Today's Appointments" />
                </StackPanel>

                <Border Grid.Row="1" Padding="24" Style="{StaticResource AdminCardStyle}">
                    <StackPanel x:Name="_appointmentsRows" Spacing="24" />
                </Border>
            </Grid>
        </ScrollViewer>

        <Button
            Canvas.ZIndex="1"
            Width="48"
            Height="48"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AdminSurfaceBrush}"
            BorderBrush="{StaticResource AdminSurfaceContainerBrush}"
            Click="OnMenuButtonClick"
            ToolTipService.ToolTip="Show menu">
            <FontIcon
                FontSize="20"
                Foreground="{StaticResource AdminTextBrush}"
                Glyph="&#xE700;" />
        </Button>

        <Border
            Canvas.ZIndex="1"
            Width="360"
            Margin="0,0,28,28"
            Padding="12"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="{StaticResource AdminSurfaceBrush}"
            BorderBrush="{StaticResource AdminSurfaceContainerBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Opacity="0.94">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="16"
                        Foreground="{StaticResource AdminMutedTextBrush}"
                        Glyph="&#xE713;" />

                    <TextBox
                        x:Name="_stationInput"
                        Grid.Column="1"
                        MinHeight="34"
                        Padding="8,5,8,5"
                        CharacterCasing="Upper"
                        FontSize="14"
                        FontWeight="SemiBold"
                        KeyDown="OnStationInputKeyDown"
                        PlaceholderText="Station B-#"
                        TextAlignment="Center" />
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="16"
                        Foreground="{StaticResource AdminMutedTextBrush}"
                        Glyph="&#xE8B6;" />

                    <TextBox
                        x:Name="_scanInput"
                        Grid.Column="1"
                        MinHeight="34"
                        Padding="8,5,8,5"
                        CharacterCasing="Upper"
                        FontSize="14"
                        FontWeight="SemiBold"
                        KeyDown="OnScanInputKeyDown"
                        PlaceholderText="Ticket or appointment"
                        TextAlignment="Center" />
                </Grid>

                <TextBlock
                    x:Name="_scanMessageText"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource AdminMutedTextBrush}"
                    MaxLines="2"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
