<Window
    x:Class="Barberia.Desktop.Views.CustomerCashBoxWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Customer Display">

    <Grid Background="#F8FAFC" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" Margin="0,0,0,16">
            <Image Source="ms-appx:///Assets/master-clips-logo.png" Height="80" />
            <TextBlock x:Name="HeaderNameText" Text="MASTERCLIPS BARBER SHOP" FontSize="48" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <!-- Idle State -->
            <StackPanel x:Name="IdlePanel" Visibility="Visible" HorizontalAlignment="Center">
                <TextBlock Text="Ready for checkout" FontSize="64" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Active State -->
            <StackPanel x:Name="ActivePanel" Visibility="Collapsed" Spacing="24">
                <!-- Ticket Info -->
                <Grid Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Customer" FontSize="20" Foreground="#64748B" />
                        <TextBlock x:Name="CustomerNameText" Text="John" FontSize="36" FontWeight="SemiBold" Foreground="#0F172A" />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                        <TextBlock Text="Barber &amp; Station" FontSize="20" Foreground="#64748B" HorizontalAlignment="Right" />
                        <TextBlock x:Name="BarberInfoText" Text="1 - Luis" FontSize="36" FontWeight="SemiBold" Foreground="#0F172A" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <!-- Service Info -->
                <Grid x:Name="ServiceInfoGrid" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="12" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="ServiceNameText" Text="Haircut" FontSize="32" Foreground="#0F172A" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ServicePriceText" Text="$25.00" FontSize="32" Foreground="#0F172A" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Addition" FontSize="24" Foreground="#64748B" Margin="0,16,0,0" x:Name="AdditionLabelText" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AdditionalAmountText" Text="$5.00" FontSize="24" Foreground="#64748B" Margin="0,16,0,0" />

                    <Rectangle Grid.Row="2" Grid.ColumnSpan="2" Height="1" Fill="#E2E8F0" Margin="0,16" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Total" FontSize="48" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TotalAmountText" Text="$30.00" FontSize="48" FontWeight="Bold" Foreground="#10B981" />
                </Grid>

                <!-- Payment Info (Cash/Zelle) -->
                <Grid x:Name="PaymentInfoGrid" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="12" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel x:Name="CashPaymentPanel" Visibility="Collapsed" Grid.Row="0" Spacing="16">
                        <Grid>
                            <TextBlock Text="Amount Received" FontSize="24" Foreground="#64748B" />
                            <TextBlock x:Name="TenderedAmountText" Text="$0.00" FontSize="24" Foreground="#0F172A" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Change Due" FontSize="32" FontWeight="Bold" Foreground="#64748B" />
                            <TextBlock x:Name="ChangeAmountText" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="ZellePaymentPanel" Visibility="Collapsed" Grid.Row="0" Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="Zelle payment selected" FontSize="32" FontWeight="SemiBold" Foreground="#3B82F6" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Final State -->
            <StackPanel x:Name="FinalStatePanel" Visibility="Collapsed" HorizontalAlignment="Center">
                <TextBlock x:Name="FinalStateMessageText" Text="Payment complete. Thank you." FontSize="56" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Please review your ticket before payment" FontSize="20" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,16,0,0" x:Name="FooterText" />
    </Grid>
</Window>
