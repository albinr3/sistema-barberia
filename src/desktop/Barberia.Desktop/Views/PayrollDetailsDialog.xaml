<ContentDialog
    x:Class="Barberia.Desktop.Views.PayrollDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FFFFFFFF"
    CornerRadius="12"
    MaxWidth="800"
    CloseButtonText="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
        <SolidColorBrush x:Key="PayrollSurfaceContainerHighestBrush" Color="#FFE2E2E5" />
        <SolidColorBrush x:Key="PayrollSurfaceContainerLowBrush" Color="#FFF3F3F6" />
        <SolidColorBrush x:Key="PayrollTextBrush" Color="#FF1A1C1E" />
        <SolidColorBrush x:Key="PayrollMutedTextBrush" Color="#FF444655" />
        <SolidColorBrush x:Key="PayrollPrimaryBrush" Color="#FF001387" />
    </ContentDialog.Resources>

    <Grid MinWidth="750" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Background="{StaticResource PayrollSurfaceContainerLowBrush}" Padding="24,16" BorderBrush="{StaticResource PayrollSurfaceContainerHighestBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock x:Name="_titleText" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PayrollTextBrush}" Text="Earnings Breakdown - Barber" />
                <TextBlock x:Name="_subtitleText" FontSize="12" Foreground="{StaticResource PayrollMutedTextBrush}" Margin="0,4,0,0" Text="Period Date" />
            </StackPanel>
        </Grid>

        <!-- Body (Table) -->
        <ScrollViewer Grid.Row="1" MaxHeight="500" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24">
                <Grid Margin="0,0,0,8" Padding="8,12" BorderBrush="{StaticResource PayrollSurfaceContainerHighestBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="DATE" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" />
                    <TextBlock Grid.Column="1" Text="SERVICES" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" TextAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="DAILY SALES" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" TextAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="COMM. %" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" TextAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="COMMISSION($)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" TextAlignment="Right" />
                </Grid>
                
                <StackPanel x:Name="_linesPanel" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Background="{StaticResource PayrollSurfaceContainerLowBrush}" Padding="24,24" BorderBrush="{StaticResource PayrollSurfaceContainerHighestBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Total Period Earnings" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PayrollMutedTextBrush}" VerticalAlignment="Center" />
            <TextBlock x:Name="_totalEarningsText" Grid.Column="1" Text="$0.00" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PayrollPrimaryBrush}" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</ContentDialog>
