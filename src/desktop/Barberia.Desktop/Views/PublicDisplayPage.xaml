<Page
    x:Class="Barberia.Desktop.Views.PublicDisplayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    VerticalAlignment="Stretch">

    <ScrollViewer
        x:Name="_displayScrollViewer"
        Background="#FFF9F9FC"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        ZoomMode="Disabled">
        <Grid
            x:Name="_displayCanvas"
            Padding="32,28,32,32"
            Background="#FFF9F9FC"
            HorizontalAlignment="Stretch"
            RowSpacing="24"
            VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border
                x:Name="_nowCallingSection"
                Background="#B3FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
                <StackPanel Spacing="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                FontSize="30"
                                Foreground="#FF001387"
                                Glyph="&#xE789;" />
                            <TextBlock
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="#FF1A1C1E"
                                Text="Now Calling" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Background="#FF0020C2"
                            CornerRadius="8"
                            Padding="12,6"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="_lastRefreshPill"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FFFFFFFF"
                                Text="Updated Just Now" />
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="_nowCallingItems"
                        ColumnSpacing="16"
                        RowSpacing="16" />
                </StackPanel>
            </Border>

            <Grid
                Grid.Row="1"
                ColumnSpacing="24"
                RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border
                    Background="#B3FFFFFF"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                    <StackPanel Spacing="16">
                        <Border BorderBrush="#FFC5C5D8" BorderThickness="0,0,0,1" Padding="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon
                                        FontSize="25"
                                        Foreground="#FF444655"
                                        Glyph="&#xE8FD;" />
                                    <TextBlock
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Foreground="#FF1A1C1E"
                                        Text="Waiting List" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="#FF444655">
                                    <Run Text="Total Wait: " />
                                    <Run
                                        x:Name="_waitingTotalText"
                                        FontWeight="Bold"
                                        Foreground="#FF001387"
                                        Text="0" />
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Grid
                            x:Name="_waitingItems"
                            ColumnSpacing="10"
                            RowSpacing="10" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="#B3FFFFFF"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                    <StackPanel Spacing="16">
                        <Border BorderBrush="#FFC5C5D8" BorderThickness="0,0,0,1" Padding="0,0,0,14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    FontSize="25"
                                    Foreground="#FF001387"
                                    Glyph="&#xE716;" />
                                <TextBlock
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Foreground="#FF1A1C1E"
                                    Text="Barber Status" />
                            </StackPanel>
                        </Border>

                        <Grid
                            x:Name="_barberItems"
                            ColumnSpacing="16"
                            RowSpacing="16" />

                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FF444655"
                            Text="Need assistance? Please see the front desk." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
