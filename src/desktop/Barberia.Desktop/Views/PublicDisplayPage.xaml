<Page
    x:Class="Barberia.Desktop.Views.PublicDisplayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE8A7;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="5">
                        <TextBlock
                            Style="{StaticResource HeroTitleTextStyle}"
                            Text="Sala de espera" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Turnos, llamados y citas desde la base local" />
                        <TextBlock
                            x:Name="_lastRefreshText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border
                        x:Name="_statusBadge"
                        Grid.Column="2"
                        Style="{StaticResource StatusBadgeStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="7">
                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource AccentGreenBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="_statusBadgeText"
                                Style="{StaticResource StatusBadgeTextStyle}"
                                Text="Local" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Llamados" />
                            <TextBlock
                                x:Name="_calledCountText"
                                FontSize="34"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGoldMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGoldTextBrush}"
                                Glyph="&#xE789;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="En sala" />
                            <TextBlock
                                x:Name="_waitingCountText"
                                FontSize="34"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGreenMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGreenTextBrush}"
                                Glyph="&#xE81C;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Citas proximas" />
                            <TextBlock
                                x:Name="_appointmentCountText"
                                FontSize="34"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentBlueMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentBlueTextBrush}"
                                Glyph="&#xE787;" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    ColumnSpacing="14"
                    RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.RowSpan="2"
                        Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Llamados ahora" />
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Turnos listos para pasar" />
                            </StackPanel>
                            <StackPanel
                                x:Name="_calledTurns"
                                Spacing="12" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Proximos en cola" />
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Walk-ins y citas ya registradas" />
                            </StackPanel>
                            <StackPanel
                                x:Name="_waitingTurns"
                                Spacing="10" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Barberos" />
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Disponibilidad visible de la sala" />
                            </StackPanel>
                            <StackPanel
                                x:Name="_barberStates"
                                Spacing="10" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Citas programadas" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Reservas sincronizadas hacia local" />
                        </StackPanel>
                        <StackPanel
                            x:Name="_appointments"
                            Spacing="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
