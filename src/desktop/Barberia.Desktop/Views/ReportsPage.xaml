<Page
    x:Class="Barberia.Desktop.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer Style="{StaticResource ScreenScrollViewerStyle}">
        <StackPanel Style="{StaticResource ScreenContentStackStyle}">
            <Border Style="{StaticResource HeroCardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroIconBoxStyle}">
                        <FontIcon
                            FontSize="30"
                            Foreground="{StaticResource SurfaceBrush}"
                            Glyph="&#xE9D2;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="5">
                        <TextBlock
                            Style="{StaticResource HeroTitleTextStyle}"
                            Text="Reportes locales" />
                        <TextBlock
                            FontSize="15"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Operacion, efectivo y comisiones desde SQLite" />
                        <TextBlock
                            x:Name="_lastRefreshText"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Spacing="10">
                        <Border
                            x:Name="_statusBadge"
                            Style="{StaticResource StatusBadgeStyle}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="7">
                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Fill="{StaticResource AccentGreenBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="_statusBadgeText"
                                    Style="{StaticResource StatusBadgeTextStyle}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="8">
                            <DatePicker
                                x:Name="_reportDatePicker"
                                MinWidth="210" />
                            <Button
                                MinHeight="42"
                                Click="OnRefreshClick"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                ToolTipService.ToolTip="Actualizar reporte local">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <FontIcon
                                        FontSize="16"
                                        Glyph="&#xE72C;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Actualizar" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Check-ins" />
                            <TextBlock
                                x:Name="_checkInsText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGreenMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGreenTextBrush}"
                                Glyph="&#xE8A5;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Cierres" />
                            <TextBlock
                                x:Name="_completedText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentBlueMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentBlueTextBrush}"
                                Glyph="&#xE73E;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Efectivo" />
                            <TextBlock
                                x:Name="_cashText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource AccentGoldMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource AccentGoldTextBrush}"
                                Glyph="&#xE8C7;" />
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="3"
                    Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Comision" />
                            <TextBlock
                                x:Name="_commissionText"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Border
                            Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="19"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Glyph="&#xE9D2;" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid
                ColumnSpacing="14"
                RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Barberos" />
                            <TextBlock
                                Style="{StaticResource SmallMutedTextStyle}"
                                Text="Cierres y efectivo del dia" />
                        </StackPanel>
                        <StackPanel
                            x:Name="_barberRows"
                            Spacing="10" />
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="14">
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Operacion" />
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Resumen de turnos locales" />
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Walk-ins" />
                                    <TextBlock
                                        x:Name="_walkInsText"
                                        Grid.Column="1"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Citas" />
                                    <TextBlock
                                        x:Name="_appointmentsText"
                                        Grid.Column="1"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Activos" />
                                    <TextBlock
                                        x:Name="_activeTurnsText"
                                        Grid.Column="1"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="No show / cancelados" />
                                    <TextBlock
                                        x:Name="_issuesText"
                                        Grid.Column="1"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <TextBlock
                                    x:Name="_messageText"
                                    Style="{StaticResource SmallMutedTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Pagos recientes" />
                                <TextBlock
                                    Style="{StaticResource SmallMutedTextStyle}"
                                    Text="Ultimos cierres en autocaja" />
                            </StackPanel>
                            <StackPanel
                                x:Name="_paymentRows"
                                Spacing="10" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8FB;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Local" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Lee SQLite y no requiere internet." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE8C7;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Efectivo" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Solo cierres registrados en autocaja." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Style="{StaticResource NoteCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource NoteIconBoxStyle}">
                            <FontIcon
                                FontSize="18"
                                Foreground="{StaticResource AccentGreenBrush}"
                                Glyph="&#xE9D2;" />
                        </Border>
                        <TextBlock
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Comision" />
                        <TextBlock
                            Style="{StaticResource SmallMutedTextStyle}"
                            Text="Usa la comision guardada segun el porcentaje del barbero al momento del cierre." />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
