<Window
    x:Class="Barberia.Desktop.Views.ConnectionBlockedWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Barberia Station Offline">

    <Grid
        Padding="36"
        Background="{StaticResource AppBackgroundBrush}">
        <StackPanel
            MaxWidth="720"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="18">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="PC3 connection required" />
            <TextBlock
                x:Name="_roleText"
                FontSize="16"
                Foreground="{StaticResource TextSecondaryBrush}" />
            <Border
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <TextBlock
                    x:Name="_messageText"
                    FontSize="15"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    TextWrapping="WrapWholeWords" />
            </Border>
            <TextBlock
                FontSize="13"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="Start Barberia.Operations on PC3, confirm the network connection, then reopen this station." />
        </StackPanel>
    </Grid>
</Window>
