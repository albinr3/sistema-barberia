<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF8F9FB" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF8F9FB" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#FFE2E6EB" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1E1F22" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF656C74" />

    <SolidColorBrush x:Key="SidebarBrush" Color="#FF1E1D1B" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#FF2A2825" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#FF3D3A36" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#FFE8E6E0" />
    <SolidColorBrush x:Key="SidebarTextMutedBrush" Color="#FFB8B5AE" />

    <SolidColorBrush x:Key="AccentGoldBrush" Color="#FFF2B558" />
    <SolidColorBrush x:Key="AccentGoldBorderBrush" Color="#FFD5983E" />
    <SolidColorBrush x:Key="AccentGoldMutedBrush" Color="#FFFFF7E8" />
    <SolidColorBrush x:Key="AccentGoldTextBrush" Color="#FF7A5215" />

    <SolidColorBrush x:Key="AccentGreenBrush" Color="#FF1F7768" />
    <SolidColorBrush x:Key="AccentGreenMutedBrush" Color="#FFEBF8F4" />
    <SolidColorBrush x:Key="AccentGreenBorderBrush" Color="#FFB5E0D3" />
    <SolidColorBrush x:Key="AccentGreenTextBrush" Color="#FF116958" />
    <SolidColorBrush x:Key="AccentGreenIconBrush" Color="#FF117F68" />

    <SolidColorBrush x:Key="AccentBlueMutedBrush" Color="#FFF0F4FA" />
    <SolidColorBrush x:Key="AccentBlueBorderBrush" Color="#FFC5CFDD" />
    <SolidColorBrush x:Key="AccentBlueTextBrush" Color="#FF3F4E61" />

    <SolidColorBrush x:Key="ErrorMutedBrush" Color="#FFFFF0EE" />
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="#FFE7AAA2" />
    <SolidColorBrush x:Key="ErrorTextBrush" Color="#FF9A3A2F" />

    <Style x:Key="ScreenScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    </Style>

    <Style x:Key="ScreenContentStackStyle" TargetType="StackPanel">
        <Setter Property="Padding" Value="32,28,32,32" />
        <Setter Property="Spacing" Value="18" />
    </Style>

    <Style x:Key="SurfaceCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="HeroCardBorderStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardBorderStyle}">
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="PanelBorderStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardBorderStyle}">
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="FormPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardBorderStyle}">
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="NoteCardBorderStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardBorderStyle}">
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="InsetPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="HeroIconBoxStyle" TargetType="Border">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource AccentGreenBrush}" />
    </Style>

    <Style x:Key="NoteIconBoxStyle" TargetType="Border">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource AccentGreenMutedBrush}" />
    </Style>

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentGreenMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8,12,8" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SmallMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AccentGreenTextBrush}" />
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="Padding" Value="16,10,16,10" />
        <Setter Property="Background" Value="{StaticResource AccentGoldBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentGoldBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SidebarBrush}" />
    </Style>

    <Style x:Key="OperationalTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="FontSize" Value="17" />
    </Style>

    <Style x:Key="OperationalComboBoxStyle" TargetType="ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

</ResourceDictionary>
