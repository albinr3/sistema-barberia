<Window
    x:Class="Barberia.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Barberia System">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="_navigationColumn" Width="292" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="_sidebar"
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">
            <Grid Padding="18,22,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="42"
                        Height="42"
                        Background="{StaticResource AccentGoldBrush}"
                        CornerRadius="8">
                        <FontIcon
                            FontSize="22"
                            Foreground="{StaticResource SidebarBrush}"
                            Glyph="&#xE7C9;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="12,1,0,0"
                        Spacing="1">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="Barberia" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource SidebarTextMutedBrush}"
                            Text="Local system" />
                    </StackPanel>
                </Grid>

                <StackPanel
                    x:Name="_navigationItems"
                    Grid.Row="1"
                    Spacing="8" />

                <Border
                    Grid.Row="2"
                    Background="{StaticResource SidebarSurfaceBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                    <StackPanel Spacing="3">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="Offline-first" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource SidebarTextMutedBrush}"
                            Text="Runs without internet dependency"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border
                x:Name="_moduleHeader"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="32,22,32,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="_header"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock
                            x:Name="_subtitle"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource StatusBadgeStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <FontIcon
                                FontSize="14"
                                Foreground="{StaticResource AccentGreenIconBrush}"
                                Glyph="&#xE73E;" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource AccentGreenTextBrush}"
                                Text="Local Phase 1" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ContentControl
                x:Name="_contentHost"
                Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
