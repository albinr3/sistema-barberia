<Window
    x:Class="Barberia.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Barberia System">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="_navigationColumn" Width="256" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="_sidebar"
            Grid.Column="0"
            Background="#FFF3F3F6"
            BorderBrush="#FFE8E8EA"
            BorderThickness="0,0,1,0">
            <Grid Padding="16,24,16,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="8,0,8,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="#FF001387"
                        CornerRadius="4">
                        <FontIcon
                            FontSize="18"
                            Foreground="#FFFFFFFF"
                            Glyph="&#xE8C6;" />
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#FF001387"
                            Text="Master Clips" />
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FF444655"
                            CharacterSpacing="50"
                            Text="ADMIN PORTAL" />
                    </StackPanel>
                </Grid>

                <StackPanel
                    x:Name="_navigationItems"
                    Grid.Row="1"
                    Spacing="4" />

                <Border
                    Grid.Row="2"
                    BorderBrush="#FFE2E2E5"
                    BorderThickness="0,1,0,0"
                    Padding="0,16,0,0">
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border
                x:Name="_moduleHeader"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="32,22,32,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="_header"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock
                            x:Name="_subtitle"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource StatusBadgeStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <FontIcon
                                FontSize="14"
                                Foreground="{StaticResource AccentGreenIconBrush}"
                                Glyph="&#xE73E;" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource AccentGreenTextBrush}"
                                Text="Local Phase 1" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ContentControl
                x:Name="_contentHost"
                Grid.Row="1"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
